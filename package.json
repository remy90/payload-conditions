{
  "name": "next-latest-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types",
    "generate:graphQLSchema": "PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:graphQLSchema"
  },
  "engines": {
    "node": ">=18.19.0"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "3.0.0-alpha.48",
    "@payloadcms/db-postgres": "3.0.0-alpha.48",
    "@payloadcms/next": "3.0.0-alpha.48",
    "@payloadcms/richtext-lexical": "3.0.0-alpha.48",
    "@payloadcms/richtext-slate": "3.0.0-alpha.48",
    "@payloadcms/ui": "3.0.0-alpha.48",
    "cross-env": "^7.0.3",
    "next": "14.2.0-canary.7",
    "payload": "3.0.0-alpha.48",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "0.33.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.28",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.1.3",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  },
  "packageManager": "pnpm@8.15.4"
}
